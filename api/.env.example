# Copy to Railway service variables (or api/.env locally).
# Generate secrets: python -c "import secrets; print(secrets.token_hex(32))"

DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
SECRET_KEY=change-me
JWT_SECRET_KEY=change-me
EMAIL_SENDER_API_KEY=re_xxxxxxxx
RESEND_FROM_EMAIL=REPSA <noreply@repsa.org>

# Optional
YEAR_FILTER_LIMIT=2023
REALTIME_CACHE_TIMEOUT=60
CORS_ORIGINS=https://repsa.org,https://www.repsa.org

# One-time table creation (set for first deploy, then remove)
# DB_AUTO_CREATE_TABLES=true
